#ifndef DMA_H
#define DMA_H
#include <QObject>
#include <QDebug>
#include "ftdi.h"
#include "J2534.h"
#include "QTimer"
#include <QStack>
#include <QTime>

class window_manager
{
public:
    QObjectList list_window = {};    //список для динамически созданных таблиц что бы разгрузить событие таймера
    QObjectList list_button = {};
    QObjectList list_widget = {};
